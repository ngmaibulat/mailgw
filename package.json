{
  "name": "mailgw-monorepo",
  "version": "0.1.6",
  "description": "Mail gateway monorepo (Haraka router + log service)",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "mailgw": "pnpm --filter @aibulat/mailgw",
    "webui": "pnpm --filter mailgw-webui",
    "start": "pnpm --filter @aibulat/mailgw start",
    "dev": "pnpm --filter @aibulat/mailgw dev",
    "webui:dev": "pnpm --filter mailgw-webui dev",
    "webui:start": "pnpm --filter mailgw-webui start",
    "certs": "bun certs/src/generate.ts",
    "test": "pnpm --filter @aibulat/mailgw test",
    "test:logservice": "cd logservice && bun test tests/",
    "test:e2e": "bun test tests/",
    "test:e2e:api": "bun test tests/api",
    "test:e2e:smtp": "bun test tests/smtp",
    "build:mailgw": "bash mailgw/container-push.sh",
    "build:logservice": "bash logservice/container-push.sh",
    "build:webui": "bash webui-express/container-push.sh",
    "build:containers": "pnpm run build:mailgw && pnpm run build:logservice && pnpm run build:webui"
  },
  "author": "Aibulat",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "^1.3.14"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
