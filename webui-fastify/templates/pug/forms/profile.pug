extends ../page.pug
block content
  +pageHeader('Profile')
  .profile-identity
    .profile-avatar= email.charAt(0).toUpperCase()
    .profile-meta
      .profile-email= email
      .profile-role Administrator
  .card.form-card
    .card-body
      h2.card-title Change password
      if error
        .alert.alert-danger= error
      if success
        .alert.alert-success= success
      form#change-password(method='post' action='/profile')
        .form-field
          label(for='current') Current password
          input#current.form-control(type='password' name='current' placeholder='Current password' required='')
        .form-field
          label(for='pass') New password
          input#pass.form-control(type='password' name='pass' placeholder='New password (8–20 chars)' required='')
        .form-field
          label(for='passConfirm') Confirm new password
          input#passConfirm.form-control(type='password' name='passConfirm' placeholder='Confirm new password' required='')
        .form-actions
          button#btn_submit.btn.btn-accent(type='submit') Update password
