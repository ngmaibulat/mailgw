extends ../page.pug
block content
  +pageHeader(`${action} relay`, data.host)
  if error
    .alert.alert-danger= error
  .card.form-card
    .card-body
      form#frm(method='POST')
        input(type='hidden' name='group_id' value=`${group_id}` required='')
        .form-field
          label(for='host') Host
          input#host.form-control(type='text' name='host' value=`${data.host}` required='')
        .form-field
          label(for='port') Port
          input#port.form-control(type='number' name='port' value=`${data.port}` required='')
        .form-field
          label(for='priority') Priority
          input#priority.form-control(type='number' name='priority' value=`${data.priority}` required='')
        .form-field
          label(for='auth_user') User
          input#auth_user.form-control(type='text' name='auth_user' value=`${data.auth_user}`)
        .form-field
          label(for='auth_pass') Password
          input#auth_pass.form-control(type='password' name='auth_pass' value='' placeholder=(action == 'Update' ? 'Leave blank to keep current' : ''))
        .form-actions
          button#btn_submit.btn.btn-accent(type='submit')= action
          a.btn.btn-ghost(href=`/config/relaygrp/${group_id}`) Cancel
