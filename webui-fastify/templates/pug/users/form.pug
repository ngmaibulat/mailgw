extends ../page.pug
block content
  +pageHeader(`${action} user`)
  if error
    .alert.alert-danger= error
  .card.form-card
    .card-body
      form#frm(method='POST')
        .form-field
          label(for='email') Email
          input#email.form-control(type='email' name='email' value=`${data.email}` required='')
        .form-field
          label(for='pass') Password
          if action === 'Update'
            input#pass.form-control(type='password' name='pass' placeholder='Leave blank to keep current')
          else
            input#pass.form-control(type='password' name='pass' placeholder='8–20 characters' required='')
        .form-actions
          button#btn_submit.btn.btn-accent(type='submit')= action
          a.btn.btn-ghost(href='/users') Cancel
