//- Base layout for every authenticated page.
//- Mixins declared here are in scope inside child `block content` bodies.

//- ---- icon set (inline SVG, stroke = currentColor) ----------------------
mixin icon(name)
  if name == 'logo'
    svg.ic(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
      path(d='M4 5h16v14H4z')
      path(d='M4 7l8 6 8-6')
  else if name == 'plus'
    svg.ic(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
      path(d='M12 5v14M5 12h14')
  else if name == 'edit'
    svg.ic(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
      path(d='M12 20h9')
      path(d='M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z')
  else if name == 'trash'
    svg.ic(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
      path(d='M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6')
  else if name == 'mail'
    svg.ic(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
      path(d='M4 5h16v14H4z')
      path(d='M4 7l8 6 8-6')
  else if name == 'plug'
    svg.ic(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
      path(d='M9 2v6M15 2v6')
      path(d='M7 8h10v3a5 5 0 0 1-10 0z')
      path(d='M12 16v6')
  else if name == 'route'
    svg.ic(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
      circle(cx='6' cy='19' r='2')
      circle(cx='18' cy='5' r='2')
      path(d='M8 19h7a3 3 0 0 0 3-3V7')
  else if name == 'users'
    svg.ic(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
      path(d='M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2')
      circle(cx='9' cy='7' r='4')
      path(d='M22 21v-2a4 4 0 0 0-3-3.87')
  else if name == 'activity'
    svg.ic(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
      path(d='M3 12h4l3 8 4-16 3 8h4')
  else if name == 'search'
    svg.ic(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
      circle(cx='11' cy='11' r='7')
      path(d='M21 21l-4-4')
  else if name == 'hash'
    svg.ic(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
      path(d='M4 9h16M4 15h16M10 3L8 21M16 3l-2 18')
  else if name == 'arrow'
    svg.ic(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
      path(d='M5 12h14M13 6l6 6-6 6')

//- ---- page header (title + optional actions block) ----------------------
mixin pageHeader(title, sub)
  header.page-head
    h1.page-title
      = title
      if sub
        span.page-title-sub  #{sub}
    if block
      .page-actions
        block

doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(name='color-scheme' content='dark')
    link(rel='stylesheet' href='/lib/bootstrap.css')
    link(rel='stylesheet' href='/lib/w2ui-1.5.css')
    link(rel='stylesheet' href='/css/main.css')
    script(src='/lib/jquery-3.6.js')
    script(src='/lib/w2ui-1.5.min.js')
    script(src='/lib/bootstrap.js')
    title NGM Mail Router
  body
    nav.topbar
      a.brand(href='/')
        span.brand-mark
          +icon('logo')
        span
          b NGM
          |
          span.brand-dim Mail Router
      ul.nav-main
        li
          a.nav-link(href='/') Home
        li.nav-item.dropdown
          a.nav-link.dropdown-toggle(href='#' role='button' data-bs-toggle='dropdown' aria-expanded='false') Logs
          ul.dropdown-menu
            li: a.dropdown-item(href='/log/connection') Connection
            li: a.dropdown-item(href='/log/mails') Mails
            li: a.dropdown-item(href='/log/delivery') Delivery
            li: a.dropdown-item(href='/log/lookups') Lookups
        li.nav-item.dropdown
          a.nav-link.dropdown-toggle(href='#' role='button' data-bs-toggle='dropdown' aria-expanded='false') Config
          ul.dropdown-menu
            li: a.dropdown-item(href='/config/relaygrp') Relays
            li: a.dropdown-item(href='/config/routing') Routing
            li: a.dropdown-item(href='/users') Users
      ul.nav-right
        li
          a.nav-link(href='/profile') Profile
        li
          a.nav-link(href='/logout') Logout

    main(class=(typeof wide !== 'undefined' && wide ? 'page page-wide' : 'page'))
      block content
