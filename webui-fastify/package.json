{
  "name": "mailgw-webui-fastify",
  "version": "0.1.8",
  "description": "Admin web UI for mailgw (Fastify + Drizzle, pug, HTTP/2)",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "test": "node --test",
    "dev": "nodemon --no-warnings --watch src --watch db --ext ts,pug --exec \"node --no-warnings src/index.ts\"",
    "start": "node --no-warnings src/index.ts",
    "typecheck": "tsc",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "container:build": "bash container-build.sh",
    "container:push": "bash container-push.sh"
  },
  "keywords": [],
  "author": "Aibulat",
  "license": "Aibulat",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^8.1.1",
    "@fastify/view": "^11.1.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "fastify": "^5.4.0",
    "mysql2": "^3.22.5",
    "pug": "^3.0.4",
    "uuid": "^14.0.0",
    "zod": "^3.20.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^25.9.2",
    "@types/pug": "^2.0.10",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3"
  }
}
