# Core node config — copy to deploy/core/.env and fill in real secrets.
# deploy/core/.env is gitignored (the repo .gitignore ignores .env).

# Shared secret between this logservice and every edge mailgw node.
# Generate one with: openssl rand -hex 32
API_KEY=change-me

# MariaDB
DB_NAME=mailgw
DB_USER=mailgw
DB_PASS=change-me
DB_ROOT_PASS=change-me
