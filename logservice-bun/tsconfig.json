{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "baseUrl": ".",
    "paths": {
      "$/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"]
}
